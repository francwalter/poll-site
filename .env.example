ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Database
DB_PATH=./data/poll.db

# Email Configuration
# EMAIL_TYPE options: "sendmail" or "smtp"
EMAIL_TYPE=sendmail
SMTP_ENABLED=true

# For Sendmail (default)
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=Poll Site

# For SMTP Provider (if EMAIL_TYPE=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Site Configuration
SITE_TITLE=My Poll Site
SITE_URL=http://localhost/poll
DEBUG=false